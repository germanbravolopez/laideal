#include <winver.h>

IDI_ICON1 ICON DISCARDABLE "@CMAKE_SOURCE_DIR@/icon/lavadora.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@
 FILEFLAGSMASK   0x3fL
#ifdef _DEBUG
 FILEFLAGS       0x1L
#else
 FILEFLAGS       0x0L
#endif
 FILEOS          0x40004L
 FILETYPE        0x1L
 FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Tintoreria La Ideal\0"
            VALUE "FileDescription",  "SW for Tintoreria La Ideal\0"
            VALUE "FileVersion",      "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@\0"
            VALUE "InternalName",     "laideal\0"
            VALUE "OriginalFilename", "laideal.exe\0"
            VALUE "ProductName",      "laideal\0"
            VALUE "ProductVersion",   "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@\0"
            VALUE "LegalCopyright",   "German Bravo Lopez (C), @CURRENT_YEAR@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
