# This file is used to ignore files which are generated
# ----------------------------------------------------------------------------
# release staging dirs (releases/<version>/, deleted by release.ps1 anyway)
releases/[0-9]*/

# build files (installer is emitted into build-release/ by release.ps1)
build*

# temporary or log files
*.bak
*.tmp
*.log

# qtcreator generated files
*.pro.user*
*.txt.user*

# binaries
*.dll
*.exe
*.zip

# local settings
.claude/settings.local.json

# MkDocs documentation site build output (see mkdocs.yml / .github/workflows/docs.yml)
site/
_site/
